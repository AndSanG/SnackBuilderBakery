#!/bin/sh
while IFS=' ' read -r _local_ref _local_sha remote_ref _remote_sha; do
  if echo "$remote_ref" | grep -q 'refs/heads/master'; then
    exit 0
  fi
done

MASTER_VERSION=$(git show origin/master:package.json 2>/dev/null | grep '"version"' | sed 's/.*"version": *"\([^"]*\)".*/\1/')
CURRENT_VERSION=$(grep '"version"' package.json | sed 's/.*"version": *"\([^"]*\)".*/\1/')

if [ -z "$MASTER_VERSION" ]; then
  exit 0
fi

if [ "$MASTER_VERSION" = "$CURRENT_VERSION" ]; then
  printf "\nBump the version in package.json before pushing (currently %s).\n" "$CURRENT_VERSION"
  exit 1
fi

exit 0
